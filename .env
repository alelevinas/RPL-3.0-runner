# Shared Environment Configuration for RPL-3.0 Monorepo

# --- Backend (General) ---
JWT_SECRET="replace_with_a_secure_random_string"
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=720

# --- Database ---
DB_URL="mysql+pymysql://root:root@localhost:3306/rpl"

# --- Messaging (RabbitMQ) ---
QUEUE_URL="amqp://guest:guest@localhost:5672"

# --- Service URLs ---
FRONTEND_URL="http://localhost:8088"
USERS_API_URL="http://localhost:8000"
ACTIVITIES_API_URL="http://localhost:8001"

# --- Frontend (Next.js) ---
# Note: Next.js variables must be prefixed with NEXT_PUBLIC_ to be available in the browser
NEXT_PUBLIC_USERS_API_BASE_URL=http://localhost:8000/api/v3
NEXT_PUBLIC_ACTIVITIES_API_BASE_URL=http://localhost:8001/api/v3

# --- Email (SMTP) ---
SMTP_SERVER="smtp.gmail.com"
SMTP_PORT=465
RPL_HELP_EMAIL_USER="your-email@gmail.com"
RPL_HELP_EMAIL_PASSWORD="your-app-password"

# --- Runner ---
RUNNER_API_KEY="generate_a_secure_api_key"
URL_RPL_BACKEND="http://localhost:8001"
API_KEY="test_api_key"

# --- AI Integration ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
